#' Compute AGC and asymptotic variance for single predictor (IID, v2)
#'
#' @param y_rank numeric vector of average ranks for Y
#' @param x_rank numeric vector of average ranks for X
#' @return List with agc, var (asymptotic variance, NOT divided by n), var_ind
#' @keywords internal
#' @noRd
Sigma_agc_v2 <- function(y_rank, x_rank) {
  N <- length(y_rank)
  
  var_y_rank <- sum((y_rank - mean(y_rank))^2) / N
  zeta_3Y <- 1 - (12 / N^2) * var_y_rank
  k_zeta <- prob_y(y_rank)^2 - zeta_3Y
  sigma_zeta <- 9 * mean(k_zeta^2)
  
  result <- comp_rho_agc(y_rank, x_rank)
  rho <- result$rho
  agc <- result$agc
  
  factor_val <- 1 / ((1 - zeta_3Y)^2)
  
  # Use Fenwick-tree kernel
  k_p <- kernel_agc_v2(x_rank, y_rank, rho)
  
  sigma_rho <- 9 * mean(k_p^2)
  sigma_pz <- 9 * mean(k_p * k_zeta)
  
  var_agc <- factor_val * (sigma_rho + (2 * rho * sigma_pz) / (1 - zeta_3Y) +
                             (rho^2 * sigma_zeta) / ((1 - zeta_3Y)^2))
  
  # Independence variance
  var_x_rank <- sum((x_rank - mean(x_rank))^2) / N
  zeta_3X <- 1 - (12 / N^2) * var_x_rank
  var_ind <- (1 - zeta_3X) / (1 - zeta_3Y)
  
  return(list(agc = agc, var = var_agc, var_ind = var_ind))
}


# ============================================================================
# SIGMA FUNCTIONS: Univariate HAC (Time Series)
# ============================================================================

#' Compute AGC and asymptotic variance for single predictor (HAC, v2)
#'
#' @param y_rank numeric vector of average ranks for Y
#' @param x_rank numeric vector of average ranks for X
#' @return List with agc, var (full variance with HAC), var_ind
#' @keywords internal
#' @noRd
Sigma_agc_ts_v2 <- function(y_rank, x_rank) {
  N <- length(y_rank)
  
  var_y_rank <- sum((y_rank - mean(y_rank))^2) / N
  zeta_3Y <- 1 - (12 / N^2) * var_y_rank
  k_zeta <- prob_y(y_rank)^2 - zeta_3Y
  sigma_zeta <- 9 * mean(k_zeta^2)
  
  result <- comp_rho_agc(y_rank, x_rank)
  rho <- result$rho
  agc <- result$agc
  
  factor_val <- 1 / ((1 - zeta_3Y)^2)
  
  # Use Fenwick-tree kernel
  k_p <- kernel_agc_v2(x_rank, y_rank, rho)
  
  # IID component
  sigma_rho <- 9 * mean(k_p^2)
  sigma_pz <- 9 * mean(k_p * k_zeta)
  
  var_iid <- factor_val * (
    sigma_rho + (2 * rho * sigma_pz) / (1 - zeta_3Y) +
      (rho^2 * sigma_zeta) / ((1 - zeta_3Y)^2)
  )
  
  # HAC correction
  b <- floor(2 * N^(1/3))
  
  K0_values <- k_zeta
  C_zeta_hac <- 0
  for (h in 1:b) {
    omega <- 1 - h / (b + 1)
    c_k <- sum(K0_values[1:(N - h)] * K0_values[(h + 1):N])
    C_zeta_hac <- C_zeta_hac + omega * (2 / N) * c_k
  }
  
  K1_values <- k_p
  A_spear <- 0
  B_both <- 0
  
  for (h in 1:b) {
    omega <- 1 - h / (b + 1)
    K1_lag <- K1_values[1:(N - h)]
    K1_lead <- K1_values[(h + 1):N]
    K0_lag <- K0_values[1:(N - h)]
    K0_lead <- K0_values[(h + 1):N]
    
    a_k <- sum(K1_lag * K1_lead)
    b_k <- sum(K1_lag * K0_lead + K0_lag * K1_lead)
    
    A_spear <- A_spear + omega * (2 / N) * a_k
    B_both <- B_both + omega * (1 / N) * b_k
  }
  
  var_hac <- factor_val * (
    A_spear + (2 * rho * B_both) / (1 - zeta_3Y) +
      (rho^2 * C_zeta_hac) / ((1 - zeta_3Y)^2)
  )
  
  variance <- var_iid + var_hac
  
  # Independence variance with HAC correction
  h_vec <- 1:(N - 1)
  w <- pmax(1 - abs(h_vec) / (b + 1), 0)
  
  x_grade_centered <- (x_rank - 0.5) / N - 0.5
  y_grade_centered <- (y_rank - 0.5) / N - 0.5
  
  x_autoc <- stats::acf(x_grade_centered, plot = FALSE, type = "covariance",
                        demean = FALSE, lag.max = N - 1)$acf
  y_autoc <- stats::acf(y_grade_centered, plot = FALSE, type = "covariance",
                        demean = FALSE, lag.max = N - 1)$acf
  
  rho_ind_lrv <- 144 * sum(x_autoc[1] * y_autoc[1], 2 * (w * x_autoc[-1] * y_autoc[-1]))
  var_ind <- rho_ind_lrv / ((1 - zeta_3Y)^2)
  
  return(list(agc = agc, var = variance, var_ind = var_ind))
}


