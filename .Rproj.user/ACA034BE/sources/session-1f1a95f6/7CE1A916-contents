#' Compute AGC and asymptotic covariance matrix for multiple predictors (IID, v2)
#'
#' @param y_rank numeric vector of average ranks for Y
#' @param xarray_ranks matrix of ranks (predictors x n)
#' @return List with agc_vector, Sigma, Sigma_ind
#' @keywords internal
#' @noRd
Sigma_agc_multivariate_v2 <- function(y_rank, xarray_ranks) {
  N <- length(y_rank)
  k <- nrow(xarray_ranks)
  
  var_y_rank <- sum((y_rank - mean(y_rank))^2) / N
  zeta_3Y <- 1 - (12 / N^2) * var_y_rank
  k_zeta <- prob_y(y_rank)^2 - zeta_3Y
  sigma_zeta <- 9 * mean(k_zeta^2)
  
  rhos <- numeric(k)
  agcs <- numeric(k)
  kps <- matrix(0, nrow = k, ncol = N)
  zeta_3X <- numeric(k)
  
  for (j in 1:k) {
    result <- comp_rho_agc(y_rank, xarray_ranks[j, ])
    rhos[j] <- result$rho
    agcs[j] <- result$agc
    
    # Use Fenwick-tree kernel
    kps[j, ] <- kernel_agc_v2(xarray_ranks[j, ], y_rank, rhos[j])
    
    # Compute zeta_3X for independence variance
    x_rank_j <- xarray_ranks[j, ]
    var_x_rank <- sum((x_rank_j - mean(x_rank_j))^2) / N
    zeta_3X[j] <- 1 - (12 / N^2) * var_x_rank
  }
  
  factor_val <- 1 / ((1 - zeta_3Y)^2)
  Sigma <- matrix(0, nrow = k, ncol = k)
  Sigma_ind <- matrix(0, nrow = k, ncol = k)
  
  for (j in 1:k) {
    k_p <- kps[j, ]
    sigma_rho <- 9 * mean(k_p^2)
    sigma_pz <- 9 * mean(k_p * k_zeta)
    
    var_agc <- factor_val * (
      sigma_rho + (2 * rhos[j] * sigma_pz) / (1 - zeta_3Y) +
        (rhos[j]^2 * sigma_zeta) / ((1 - zeta_3Y)^2)
    )
    Sigma[j, j] <- var_agc
    Sigma_ind[j, j] <- (1 - zeta_3X[j]) / (1 - zeta_3Y)
    
    if (j < k) {
      for (i in (j + 1):k) {
        k_p2 <- kps[i, ]
        sigma_rho2 <- 9 * mean(k_p * k_p2)
        sigma_pz2 <- 9 * mean(k_p2 * k_zeta)
        
        cov_agc <- factor_val * (
          sigma_rho2 + (rhos[j] * sigma_pz) / (1 - zeta_3Y) +
            (rhos[i] * sigma_pz2) / (1 - zeta_3Y) +
            (rhos[j] * rhos[i] * sigma_zeta) / ((1 - zeta_3Y)^2)
        )
        Sigma[j, i] <- Sigma[i, j] <- cov_agc
        
        # Independence covariance
        x_grade_j <- (xarray_ranks[j, ] - 0.5) / N - 0.5
        x_grade_i <- (xarray_ranks[i, ] - 0.5) / N - 0.5
        rho_ji <- 12 * mean(x_grade_j * x_grade_i)
        Sigma_ind[j, i] <- Sigma_ind[i, j] <- rho_ji / (1 - zeta_3Y)
      }
    }
  }
  
  return(list(agc_vector = agcs, Sigma = Sigma, Sigma_ind = Sigma_ind))
}


