# ============================================================================
# AGC V2: Fenwick Tree Optimized Functions for Large n / Continuous Data
# ============================================================================
#
# The existing kernel_ties_optim2() builds R×N and M×N sign matrices and
# performs R×M matrix multiplication.  When data is continuous (R ≈ M ≈ N),
# this becomes O(n²) in time and memory.
#
# These v2 functions replace the sign-matrix kernel with a Fenwick-tree
# approach that computes the same k_p vector in O(n log n) time and O(n)
# memory, matching the AKC v2 strategy.
#
# The downstream variance / covariance algebra (sigma_rho, sigma_pz, HAC
# loops, independence variance, etc.) is identical to the existing AGC
# code — only the kernel computation changes.
#
# Functions provided (parallel to existing AGC structure):
#   kernel_agc_v2()               - Fenwick-tree kernel  (replaces kernel_ties_optim2)
#   Sigma_agc_v2()                - univariate IID
#   Sigma_agc_ts_v2()             - univariate HAC (time series)
#   Sigma_agc_multivariate_v2()   - multivariate IID
#   Sigma_agc_multivariate_ts_v2()- multivariate HAC (time series)
# ============================================================================


# ============================================================================
# FENWICK TREE HELPERS  (reuse from akc_functions.R if already loaded,
#                        otherwise self-contained here)
# ============================================================================

if (!exists("fenwick_create", mode = "function")) {
  fenwick_create <- function(n) numeric(n)
  
  fenwick_update <- function(tree, i, delta = 1) {
    n <- length(tree)
    while (i <= n) {
      tree[i] <- tree[i] + delta
      i <- i + bitwAnd(i, -i)
    }
    tree
  }
  
  fenwick_query <- function(tree, i) {
    if (i <= 0) return(0)
    s <- 0
    while (i > 0) {
      s <- s + tree[i]
      i <- i - bitwAnd(i, -i)
    }
    s
  }
}


# ============================================================================
# CORE KERNEL: O(n log n) replacement for kernel_ties_optim2
# ============================================================================
#
# kernel_ties_optim2 computes, for each observation i (returned in original
# order), the influence function value:
#
#   k_p[i] = 4*(g_1[i] + g_2[i] + G_x[i]*G_y[i] - G_y[i] - G_x[i]) + 1 - rho
#
# where G_x[i] = (rank_x[i] - 0.5)/N   (grade of x)
#       G_y[i] = (rank_y[i] - 0.5)/N   (grade of y)
#
#   g_1[i] = (1/4N) * sum_k  [ mean_sign_x(x_i, y_k) + 2*G_x[i] + 2*G_y[k] - 1 ]
#            summed only over k that share the same y-value as observation i
#            (i.e. y_rank[k] == y_rank[i])
#
#   g_2[i] = (1/4N) * sum_j  n_j * [ mean_sign_x(x_i, y_unique_j) + 2*G_x[i] + 2*G_y_unique_j - 1 ]
#
# and   mean_sign_x(x_i, y_j) = (1/N) * sum_k sign(x_rank[k] - x_rank[i]) * sign(y_rank[k] - y_rank[j])
#
# The key quantity to compute efficiently is H_bar_agc(x_i, y_j) which counts
# concordance/discordance patterns.  This is the bivariate empirical CDF with
# midrank adjustment — exactly H_bar from the AKC code.
#
# Relationship:  mean_sign_x(x_i, y_j) = 4*H_bar(x_i, y_j) - 2*F_bar(x_i) - 2*G_bar(y_j) + 1
#
# So the full expression inside all_exp is:
#   mean_sign_x + 2*G_x[i] + 2*G_y[j] - 1
#   = 4*H_bar(x_i, y_j) - 2*F_bar(x_i) - 2*G_bar(y_j) + 1 + 2*G_x[i] + 2*G_y[j] - 1
#   = 4*H_bar(x_i, y_j) - 2*F_bar(x_i) + 2*G_x[i] - 2*G_bar(y_j) + 2*G_y[j]
#
# Note: For ranks, F_bar(x_i) = G_x[i] and G_bar(y_j) = G_y[j], so this simplifies to:
#   = 4*H_bar(x_i, y_j)
#
# Therefore:
#   g_1[i] = (1/N) * sum_{k: y_k == y_i} H_bar(x_i, y_k)
#          = (n_{y_i}/N) * H_bar(x_i, y_i)    [since all k with same y give same H_bar]
#
#   g_2[i] = (1/N) * sum_j n_j * H_bar(x_i, y_unique_j)
#          = (1/N) * sum_k H_bar(x_i, y_k)     [expanding unique groups back to all obs]
#          = E_k[ H_bar(x_i, y_k) ]
#
# And the full kernel becomes:
#   k_p[i] = 4*(g_1[i] + g_2[i] + G_x[i]*G_y[i] - G_y[i] - G_x[i]) + 1 - rho
#
# where g_1 and g_2 require computing H_bar(x_i, y_j) for specific (i, j) combinations.
#
# STRATEGY:
# Instead of materializing all H_bar values, we compute the needed aggregates
# directly using Fenwick trees and sorting, achieving O(n log n) overall.
# ============================================================================

kernel_agc_v2 <- function(x_rank, y_rank, rho) {
  #' Fenwick-tree kernel for AGC influence function values
  #'
  #' Computes the same k_p vector as kernel_ties_optim2 but in O(n log n)
  
  #' time and O(n) memory.  Operates on rank vectors directly (not pre-sorted).
  #'
  #' @param x_rank numeric vector of average ranks for X
  #' @param y_rank numeric vector of average ranks for Y
  #' @param rho    Spearman-style correlation (12/N^3)*sum((x-mean)*(y-mean))
  #' @return numeric vector k_p of length N (influence function values)
  #' @keywords internal
  #' @noRd
  
  N <- length(x_rank)
  
  # --- Grades ---
  G_x <- (x_rank - 0.5) / N
  G_y <- (y_rank - 0.5) / N
  
  # === Compute g_2[i] = mean_k H_bar(x_i, y_k) ===
  # H_bar(x_i, y_k) = [ #{j: x_j < x_i, y_j < y_k}
  #                    + 0.5*#{j: x_j == x_i, y_j < y_k}
  #                    + 0.5*#{j: x_j < x_i, y_j == y_k}
  #                    + 0.25*#{j: x_j == x_i, y_j == y_k} ] / N
  #
  # g_2[i] = (1/N) * sum_k H_bar(x_i, y_k)
  #
  # Expanding: g_2[i] = (1/N^2) * sum_k [
  #   #{j: x_j < x_i, y_j < y_k} + 0.5*#{j: x_j == x_i, y_j < y_k}
  #   + 0.5*#{j: x_j < x_i, y_j == y_k} + 0.25*#{j: x_j == x_i, y_j == y_k} ]
  #
  # This requires summing over all k for each i, which appears O(n^2).
  # However, note that:
  #   sum_k #{j: x_j < x_i, y_j < y_k} = sum_j 1(x_j < x_i) * #{k: y_k > y_j}
  #                                       = sum_j 1(x_j < x_i) * (N - rank_y[j] + 0.5 - 0.5*n_{y_j})
  # ... which requires careful decomposition.
  #
  # SIMPLER APPROACH: use the identity from the algebraic simplification.
  # Since we work with ranks (F_bar(x_i) = G_x[i], G_bar(y_j) = G_y[j]):
  #
  #   k_p[i] = 4*(g_1[i] + g_2[i]) + 4*G_x[i]*G_y[i] - 4*G_y[i] - 4*G_x[i] + 1 - rho
  #
  # And from the identity all_exp[i,j] = 4*H_bar(x_i, y_j) for rank data:
  #
  #   g_1[i] = (1/(4N)) * sum_{k: y_k==y_i} all_exp[i, y_i_index]
  #          = (n_{y_i} / N) * H_bar(x_i, y_i)
  #
  #   g_2[i] = (1/(4N)) * sum_j n_j * all_exp[i, j]
  #          = (1/N) * sum_k H_bar(x_i, y_k)
  #
  # So:  k_p[i] = 4 * [ (n_{y_i}/N)*H_bar(x_i,y_i) + (1/N)*sum_k H_bar(x_i,y_k) ]
  #               + 4*G_x[i]*G_y[i] - 4*G_y[i] - 4*G_x[i] + 1 - rho
  #
  # We need two quantities per observation i:
  #   (A) H_bar(x_i, y_i)          — the bivariate midrank CDF at (x_i, y_i)
  #   (B) sum_k H_bar(x_i, y_k)    — sum of bivariate midrank CDF over all k
  
  # ------------------------------------------------------------------
  # (A) Compute H_bar(x_i, y_i) for all i using Fenwick tree — O(n log n)
  # ------------------------------------------------------------------
  # H_bar(x_i, y_i) = [c_both_less + 0.5*c_xeq_yless + 0.5*c_xless_yeq + 0.25*c_both_eq] / N
  
  # Coordinate compression for Y
  Y_unique <- sort(unique(y_rank))
  M <- length(Y_unique)
  Y_compressed <- match(y_rank, Y_unique)
  
  # Coordinate compression for X
  X_unique <- sort(unique(x_rank))
  R <- length(X_unique)
  X_compressed <- match(x_rank, X_unique)
  
  # Group observations by X rank
  X_groups <- split(1:N, X_compressed)
  X_group_order <- order(as.integer(names(X_groups)))
  
  # --- Pass 1: count c_both_less and c_xless_yeq via Fenwick tree ---
  c_both_less <- integer(N)
  c_xless_yeq <- integer(N)
  
  tree <- fenwick_create(M)
  
  for (g in X_group_order) {
    indices <- X_groups[[g]]
    
    # Query for all points in this X group (tree has all points with X < X[i])
    for (i in indices) {
      yc <- Y_compressed[i]
      if (yc > 1) {
        c_both_less[i] <- fenwick_query(tree, yc - 1)
      }
      c_xless_yeq[i] <- fenwick_query(tree, yc) - fenwick_query(tree, yc - 1)
    }
    
    # Insert all points in this group into the tree
    for (i in indices) {
      tree <- fenwick_update(tree, Y_compressed[i], 1)
    }
  }
  
  # --- Pass 2: count c_xeq_yless and c_both_eq within each X group ---
  c_xeq_yless <- integer(N)
  c_both_eq <- integer(N)
  
  for (g in seq_along(X_groups)) {
    indices <- X_groups[[g]]
    if (length(indices) == 1) {
      c_both_eq[indices] <- 1
      next
    }
    
    # Sort by Y within this X group
    y_in_group <- Y_compressed[indices]
    ord <- order(y_in_group)
    sorted_idx <- indices[ord]
    sorted_y <- y_in_group[ord]
    
    cumcount <- 0
    prev_y <- -1
    same_y_count <- 0
    
    for (k in seq_along(sorted_idx)) {
      i <- sorted_idx[k]
      yc <- sorted_y[k]
      
      if (yc == prev_y) {
        same_y_count <- same_y_count + 1
      } else {
        cumcount <- cumcount + same_y_count
        same_y_count <- 1
        prev_y <- yc
      }
      c_xeq_yless[i] <- cumcount
    }
    
    # Count same (X, Y) pairs
    xy_key <- paste0(X_compressed[indices], "_", Y_compressed[indices])
    pair_counts <- table(xy_key)
    for (i in indices) {
      pk <- paste0(X_compressed[i], "_", Y_compressed[i])
      c_both_eq[i] <- pair_counts[[pk]]
    }
  }
  
  H_bar_ii <- (c_both_less + 0.5 * c_xeq_yless + 0.5 * c_xless_yeq + 0.25 * c_both_eq) / N
  
  # ------------------------------------------------------------------
  # (B) Compute S[i] = sum_k H_bar(x_i, y_k) for all i — O(n log n)
  # ------------------------------------------------------------------
  # Expand H_bar(x_i, y_k) = [A(x_i,y_k) + 0.5*B(x_i,y_k) + 0.5*C(x_i,y_k) + 0.25*D(x_i,y_k)] / N
  # where:
  #   A(x_i,y_k) = #{j: x_j < x_i, y_j < y_k}
  #   B(x_i,y_k) = #{j: x_j == x_i, y_j < y_k}
  #   C(x_i,y_k) = #{j: x_j < x_i, y_j == y_k}
  #   D(x_i,y_k) = #{j: x_j == x_i, y_j == y_k}
  #
  # sum_k A(x_i,y_k) = sum_j 1(x_j < x_i) * #{k: y_k > y_j}
  #   where #{k: y_k > y_j} = N - rank_y[j] + 0.5*(n_{y_j} - 1)   [using midranks]
  #   Actually: #{k: y_k > y_j} = #{k: y_rank[k] > y_rank[j]} (strict)
  #   Since y_rank uses average ties: #{k: y_k > y_j} + #{k: y_k == y_j} + #{k: y_k < y_j} = N
  #   #{k: y_k < y_j} = y_rank[j] - 0.5*n_{y_j} - 0.5 + 0.5 = ... 
  #
  # This gets complex.  A cleaner decomposition:
  #
  # sum_k H_bar(x_i, y_k) = sum_k [ P(X < x_i, Y < y_k) + 0.5*P(X==x_i, Y<y_k)
  #                                + 0.5*P(X<x_i, Y==y_k) + 0.25*P(X==x_i, Y==y_k) ]
  #   where P() are empirical proportions (count / N).
  #
  # = (1/N) sum_k [ #{j: x_j<x_i, y_j<y_k}/N + 0.5*#{j: x_j==x_i, y_j<y_k}/N
  #               + 0.5*#{j: x_j<x_i, y_j==y_k}/N + 0.25*#{j: x_j==x_i, y_j==y_k}/N ]
  #
  # Swap sums:
  # = (1/N) sum_j [ #{k: y_k > y_j}*1(x_j<x_i)/N + 0.5*#{k: y_k > y_j}*1(x_j==x_i)/N
  #               + 0.5*#{k: y_k == y_j}*1(x_j<x_i)/N + 0.25*#{k: y_k==y_j}*1(x_j==x_i)/N ]
  #
  # Define for each j:
  #   n_gt_j = #{k: y_k > y_j} = N - y_rank[j] - 0.5*(n_{y_j} - 1)
  #          ... let's just compute it directly.
  
  # Count of observations with each unique y value
  y_tab <- table(factor(y_rank, levels = Y_unique))
  n_y <- as.numeric(y_tab)  # n_y[m] = count of obs with Y_compressed == m
  
  # For each observation j, compute:
  #   n_y_gt[j] = #{k: y_rank[k] > y_rank[j]}  (strict greater)
  #   n_y_eq[j] = #{k: y_rank[k] == y_rank[j]}  (equals, including j itself)
  n_y_eq <- n_y[Y_compressed]
  n_y_lt <- numeric(N)
  # #{k: y_k < y_j} : cumulative count of y values strictly less
  # Using the sorted unique values:
  cum_n_y <- c(0, cumsum(n_y))
  n_y_lt <- cum_n_y[Y_compressed]
  n_y_gt <- N - n_y_lt - n_y_eq
  
  # Similarly for X:
  x_tab <- table(factor(x_rank, levels = X_unique))
  n_x <- as.numeric(x_tab)
  n_x_eq <- n_x[X_compressed]
  cum_n_x <- c(0, cumsum(n_x))
  n_x_lt <- cum_n_x[X_compressed]  # #{j: x_rank[j] < x_rank[i]}
  
  # Now: sum_k H_bar(x_i, y_k)
  # = (1/N) * sum_j [
  #     1(x_j < x_i) * (n_y_gt[j] + 0.5*n_y_eq[j]) / N
  #   + 1(x_j == x_i) * (0.5*n_y_gt[j] + 0.25*n_y_eq[j]) / N
  #   ]
  #
  # Wait — let me re-derive more carefully.
  # H_bar(x_i, y_k) = (1/N) * [ #{j: x_j<x_i AND y_j<y_k}
  #                            + 0.5*#{j: x_j==x_i AND y_j<y_k}
  #                            + 0.5*#{j: x_j<x_i AND y_j==y_k}
  #                            + 0.25*#{j: x_j==x_i AND y_j==y_k} ]
  #
  # sum_k H_bar(x_i, y_k)
  # = (1/N) * sum_k [ #{j: x_j<x_i, y_j<y_k} + 0.5*#{j: x_j==x_i, y_j<y_k}
  #                  + 0.5*#{j: x_j<x_i, y_j==y_k} + 0.25*#{j: x_j==x_i, y_j==y_k} ]
  #
  # Swap sums over j and k:
  # = (1/N) * sum_j [
  #     1(x_j<x_i) * #{k: y_k > y_j}          -- term A: x_j<x_i, y_j<y_k ↔ y_k>y_j
  #   + 0.5*1(x_j==x_i) * #{k: y_k > y_j}     -- term B
  #   + 0.5*1(x_j<x_i) * #{k: y_k == y_j}     -- term C
  #   + 0.25*1(x_j==x_i) * #{k: y_k == y_j}   -- term D
  #   ]
  #
  # For each j define: w_j = n_y_gt[j] + 0.5*n_y_eq[j]   (the "above-and-half" count)
  # Then terms A+B = [1(x_j<x_i) + 0.5*1(x_j==x_i)] * n_y_gt[j]
  #                   ... not quite. Let me just group:
  #
  # = (1/N) * sum_j {
  #     1(x_j<x_i)  * [ n_y_gt[j] + 0.5*n_y_eq[j] ]
  #   + 1(x_j==x_i) * [ 0.5*n_y_gt[j] + 0.25*n_y_eq[j] ]
  #   }
  
  # Define weight for each j:
  w_full <- n_y_gt + 0.5 * n_y_eq   # used when x_j < x_i
  w_half <- 0.5 * n_y_gt + 0.25 * n_y_eq  # used when x_j == x_i
  
  # Now sum_k H_bar(x_i, y_k) = (1/N) * [ sum_{j: x_j<x_i} w_full[j] + sum_{j: x_j==x_i} w_half[j] ]
  #
  # We compute sum_{j: x_j < x_i} w_full[j] for all i using Fenwick tree on X order.
  # And sum_{j: x_j == x_i} w_half[j] is a group sum.
  
  # --- Compute group sums for the "x_j == x_i" term ---
  # For each X group, sum w_half over all members
  w_half_group_sum <- numeric(R)
  for (g in seq_along(X_groups)) {
    indices <- X_groups[[g]]
    w_half_group_sum[as.integer(names(X_groups)[g])] <- sum(w_half[indices])
  }
  # Map back to observations
  sum_xeq_whalf <- w_half_group_sum[X_compressed]
  
  # --- Compute prefix sums for the "x_j < x_i" term using Fenwick tree ---
  # Process X groups in increasing order, accumulate w_full sums
  # For each observation i, we need sum of w_full[j] for all j with x_rank[j] < x_rank[i]
  
  sum_xlt_wfull <- numeric(N)
  
  # Accumulate by X group in order
  running_sum <- 0
  for (g in X_group_order) {
    indices <- X_groups[[g]]
    
    # All observations in this group get the running sum (from strictly smaller X groups)
    for (i in indices) {
      sum_xlt_wfull[i] <- running_sum
    }
    
    # Add this group's w_full to running sum
    running_sum <- running_sum + sum(w_full[indices])
  }
  
  # Combine:
  S_i <- (1 / N) * (sum_xlt_wfull + sum_xeq_whalf)
  
  # ------------------------------------------------------------------
  # Assemble k_p
  # ------------------------------------------------------------------
  # n_{y_i} for each observation
  n_yi <- n_y_eq  # already computed: count of obs with same y as obs i
  
  # g_1[i] = (n_{y_i} / N) * H_bar(x_i, y_i)
  g_1 <- (n_yi / N) * H_bar_ii
  
  # g_2[i] = (1/N) * sum_k H_bar(x_i, y_k) = S_i / N
  # Wait: S_i already has the (1/N) inside from the H_bar definition.
  # Let me re-check:
  # H_bar(x_i, y_k) = [...counts...] / N
  # sum_k H_bar(x_i, y_k) = (1/N) * sum_k [...counts...]
  # We computed S_i = (1/N) * [sum of w's] where w's are counts (not divided by N)
  # So S_i = (1/N) * sum_j {...}
  # But H_bar(x_i,y_k) has a (1/N) factor, so sum_k H_bar = (1/N)*sum_k[counts]
  # And S_i = (1/N)*sum_j[count-level w's]
  # These count-level w's correspond to sum_k of the counts inside H_bar.
  # So S_i = sum_k H_bar(x_i, y_k).  ✓
  
  g_2 <- S_i / N  # E_k[H_bar(x_i, y_k)] = (1/N)*sum_k H_bar(x_i, y_k)
  
  # Wait, in the original code:
  # g_1 = col_sums[y_group_of_i] / N  where col_sums = colSums(all_exp)
  # and all_exp[i,j] = mean_sign_x_indexed[i,j] + 2*G_x[i] + 2*G_y[j] - 1
  # g_1 is then divided by 4.
  # For rank data: all_exp[i,j] = 4*H_bar(x_i, y_j) (as shown above)
  # col_sums[j] = sum_i all_exp[i,j] = 4 * sum_i H_bar(x_i, y_j)
  # g_1[i] (for i in y-group j) = col_sums[j] / N = (4/N) * sum_i H_bar(x_i, y_j)
  # Then g_1 /= 4  → g_1[i] = (1/N) * sum_{all i'} H_bar(x_{i'}, y_j)
  #   where j is the y-group of observation i.
  # WAIT: this sums over i' (all observations), not over k with same y.
  # Let me re-read the original code more carefully.
  
  # Original code:
  #   col_sums <- colSums(all_exp)  # length M, summing over N observations (rows)
  #   g_1[observations in y-group m] <- col_sums[m] / N
  #   ...
  #   g_2 <- (all_exp %*% y_num) / N   # N x 1
  #   g_1 <- g_1 / 4
  #   g_2 <- as.vector(g_2) / 4
  #
  # So: col_sums[m] = sum_{i=1}^{N} all_exp[i, m]
  #   where all_exp[i, m] involves x_i and y_unique[m].
  #
  # g_1[i] = (1/4N) * sum_{i'=1}^{N} all_exp[i', y_group(i)]
  #        = (1/N) * sum_{i'} H_bar(x_{i'}, y_{group(i)})
  #
  # g_2[i] = (1/4N) * sum_{m=1}^{M} n_m * all_exp[i, m]
  #        = (1/N) * sum_{m} n_m * H_bar(x_i, y_unique[m])
  #        = (1/N) * sum_k H_bar(x_i, y_k)
  #
  # So g_1 sums over i' (all x's) at a fixed y, and g_2 sums over k (all y's) at a fixed x.
  # I had g_2 correct but g_1 wrong.  Let me fix g_1.
  
  # g_1[i] = (1/N) * sum_{i'=1}^{N} H_bar(x_{i'}, y_{group(i)})
  # This is: for the y-value of observation i, average H_bar across ALL x-observations.
  # Since H_bar(x_{i'}, y_j) = [#{j': x_{j'}<x_{i'}, y_{j'}<y_j} + ...] / N,
  # sum_{i'} H_bar(x_{i'}, y_j) requires summing a bivariate CDF across all x-points.
  
  # Let's compute this efficiently.
  # sum_{i'=1}^{N} H_bar(x_{i'}, y_m) for each unique y_m:
  #
  # = (1/N) * sum_{i'} [ #{j: x_j < x_{i'}, y_j < y_m}
  #                     + 0.5*#{j: x_j == x_{i'}, y_j < y_m}
  #                     + 0.5*#{j: x_j < x_{i'}, y_j == y_m}
  #                     + 0.25*#{j: x_j == x_{i'}, y_j == y_m} ]
  #
  # Term 1: sum_{i'} #{j: x_j < x_{i'}, y_j < y_m}
  #        = sum_j 1(y_j < y_m) * #{i': x_{i'} > x_j}
  #        = sum_j 1(y_j < y_m) * n_x_gt[j]
  #
  # Term 2: sum_{i'} #{j: x_j == x_{i'}, y_j < y_m}
  #        = sum_j 1(y_j < y_m) * #{i': x_{i'} == x_j}
  #        = sum_j 1(y_j < y_m) * n_x_eq[j]
  #
  # Term 3: sum_{i'} #{j: x_j < x_{i'}, y_j == y_m}
  #        = sum_j 1(y_j == y_m) * n_x_gt[j]
  #
  # Term 4: sum_{i'} #{j: x_j == x_{i'}, y_j == y_m}
  #        = sum_j 1(y_j == y_m) * n_x_eq[j]
  
  n_x_gt <- N - n_x_lt - n_x_eq
  
  # For each unique y_m, compute the sums above
  T_m <- numeric(M)
  
  for (m in 1:M) {
    mask_lt <- Y_compressed < m       # y_j < y_m (in compressed ranks)
    mask_eq <- Y_compressed == m      # y_j == y_m
    
    t1 <- sum(n_x_gt[mask_lt])
    t2 <- sum(n_x_eq[mask_lt])
    t3 <- sum(n_x_gt[mask_eq])
    t4 <- sum(n_x_eq[mask_eq])
    
    T_m[m] <- (t1 + 0.5 * t2 + 0.5 * t3 + 0.25 * t4) / N
  }
  
  # Map back to observations: g_1[i] = T_m[Y_compressed[i]] / N
  g_1 <- T_m[Y_compressed] / N
  
  # g_2[i] is already computed via S_i:
  g_2 <- S_i / N
  
  # Final kernel values
  k_p <- 4 * (g_1 + g_2 + G_x * G_y - G_y - G_x) + 1 - rho
  
  return(k_p)
}


