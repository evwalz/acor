#' Compute AGC and asymptotic covariance matrix for multiple predictors (HAC, v2)
#'
#' @param y_rank numeric vector of average ranks for Y
#' @param xarray_ranks matrix of ranks (predictors x n)
#' @return List with agc_vector, Sigma, Sigma_ind
#' @keywords internal
#' @noRd
Sigma_agc_multivariate_ts_v2 <- function(y_rank, xarray_ranks) {
  N <- length(y_rank)
  k <- nrow(xarray_ranks)
  
  var_y_rank <- sum((y_rank - mean(y_rank))^2) / N
  zeta_3Y <- 1 - (12 / N^2) * var_y_rank
  k_zeta <- prob_y(y_rank)^2 - zeta_3Y
  sigma_zeta <- 9 * mean(k_zeta^2)
  
  rhos <- numeric(k)
  agcs <- numeric(k)
  kps <- matrix(0, nrow = k, ncol = N)
  
  for (j in 1:k) {
    result <- comp_rho_agc(y_rank, xarray_ranks[j, ])
    rhos[j] <- result$rho
    agcs[j] <- result$agc
    
    # Use Fenwick-tree kernel
    kps[j, ] <- kernel_agc_v2(xarray_ranks[j, ], y_rank, rhos[j])
  }
  
  factor_val <- 1 / ((1 - zeta_3Y)^2)
  Sigma <- matrix(0, nrow = k, ncol = k)
  Sigma_ind <- matrix(0, nrow = k, ncol = k)
  
  b <- floor(2 * N^(1/3))
  h_vec <- 1:(N - 1)
  w <- pmax(1 - abs(h_vec) / (b + 1), 0)
  
  # Precompute C_zeta_hac
  K0_values <- k_zeta
  C_zeta_hac <- 0
  for (h in 1:b) {
    omega <- 1 - h / (b + 1)
    c_k <- sum(K0_values[1:(N - h)] * K0_values[(h + 1):N])
    C_zeta_hac <- C_zeta_hac + omega * (2 / N) * c_k
  }
  
  # Centered grades for independence variance
  x_grades_centered <- matrix(0, nrow = k, ncol = N)
  for (j in 1:k) {
    x_grades_centered[j, ] <- (xarray_ranks[j, ] - 0.5) / N - 0.5
  }
  y_grade_centered <- (y_rank - 0.5) / N - 0.5
  
  y_autoc <- stats::acf(y_grade_centered, plot = FALSE, type = "covariance",
                        demean = FALSE, lag.max = N - 1)$acf
  
  # Build covariance matrices
  for (j in 1:k) {
    k_p <- kps[j, ]
    sigma_rho <- 9 * mean(k_p^2)
    sigma_pz <- 9 * mean(k_p * k_zeta)
    
    # IID component
    var_iid <- factor_val * (
      sigma_rho + (2 * rhos[j] * sigma_pz) / (1 - zeta_3Y) +
        (rhos[j]^2 * sigma_zeta) / ((1 - zeta_3Y)^2)
    )
    
    # HAC correction for diagonal
    K1_values <- k_p
    A_spear <- 0
    B_both <- 0
    
    for (h in 1:b) {
      omega <- 1 - h / (b + 1)
      K1_lag <- K1_values[1:(N - h)]
      K1_lead <- K1_values[(h + 1):N]
      K0_lag <- K0_values[1:(N - h)]
      K0_lead <- K0_values[(h + 1):N]
      
      a_k <- sum(K1_lag * K1_lead)
      b_k <- sum(K1_lag * K0_lead + K0_lag * K1_lead)
      
      A_spear <- A_spear + omega * (2 / N) * a_k
      B_both <- B_both + omega * (1 / N) * b_k
    }
    
    var_hac <- factor_val * (
      A_spear + (2 * rhos[j] * B_both) / (1 - zeta_3Y) +
        (rhos[j]^2 * C_zeta_hac) / ((1 - zeta_3Y)^2)
    )
    
    Sigma[j, j] <- var_iid + var_hac
    
    # Independence variance for diagonal (HAC)
    x_grade_j <- x_grades_centered[j, ]
    xcov_0_jj <- mean(x_grade_j * x_grade_j)
    hac_sum_jj <- xcov_0_jj * y_autoc[1]
    
    for (h in 1:min(b, N - 1)) {
      xcov_h <- mean(x_grade_j[1:(N - h)] * x_grade_j[(h + 1):N] +
                       x_grade_j[(h + 1):N] * x_grade_j[1:(N - h)]) / 2
      hac_sum_jj <- hac_sum_jj + 2 * w[h] * xcov_h * y_autoc[h + 1]
    }
    Sigma_ind[j, j] <- 144 * hac_sum_jj / ((1 - zeta_3Y)^2)
    
    # Off-diagonal elements
    if (j < k) {
      for (i in (j + 1):k) {
        k_p2 <- kps[i, ]
        sigma_rho2 <- 9 * mean(k_p * k_p2)
        sigma_pz2 <- 9 * mean(k_p2 * k_zeta)
        
        # IID component
        cov_iid <- factor_val * (
          sigma_rho2 + (rhos[j] * sigma_pz) / (1 - zeta_3Y) +
            (rhos[i] * sigma_pz2) / (1 - zeta_3Y) +
            (rhos[j] * rhos[i] * sigma_zeta) / ((1 - zeta_3Y)^2)
        )
        
        # HAC correction
        A2_spear <- 0
        B_one <- 0
        B_two <- 0
        
        for (h in 1:b) {
          omega <- 1 - h / (b + 1)
          kp_lag <- k_p[1:(N - h)]
          kp_lead <- k_p[(h + 1):N]
          kp2_lag <- k_p2[1:(N - h)]
          kp2_lead <- k_p2[(h + 1):N]
          K0_lag <- K0_values[1:(N - h)]
          K0_lead <- K0_values[(h + 1):N]
          
          a_k <- sum(kp_lag * kp2_lead + kp_lead * kp2_lag)
          b_k1 <- sum(kp_lag * K0_lead + kp_lead * K0_lag)
          b_k2 <- sum(kp2_lag * K0_lead + kp2_lead * K0_lag)
          
          A2_spear <- A2_spear + omega * (1 / N) * a_k
          B_one <- B_one + omega * (1 / N) * b_k1
          B_two <- B_two + omega * (1 / N) * b_k2
        }
        
        cov_hac <- factor_val * (
          A2_spear + (rhos[j] * B_one) / (1 - zeta_3Y) +
            (rhos[i] * B_two) / (1 - zeta_3Y) +
            (rhos[j] * rhos[i] * C_zeta_hac) / ((1 - zeta_3Y)^2)
        )
        
        Sigma[j, i] <- Sigma[i, j] <- cov_iid + cov_hac
        
        # Independence covariance (HAC)
        x_grade_i <- x_grades_centered[i, ]
        xcov_0_ji <- mean(x_grade_j * x_grade_i)
        hac_sum_ji <- xcov_0_ji * y_autoc[1]
        
        for (h in 1:min(b, N - 1)) {
          xcov_h <- mean(x_grade_j[1:(N - h)] * x_grade_i[(h + 1):N] +
                           x_grade_j[(h + 1):N] * x_grade_i[1:(N - h)]) / 2
          hac_sum_ji <- hac_sum_ji + 2 * w[h] * xcov_h * y_autoc[h + 1]
        }
        Sigma_ind[j, i] <- Sigma_ind[i, j] <- 144 * hac_sum_ji / ((1 - zeta_3Y)^2)
      }
    }
  }
  
  if (k == 1) {
    return(list(agc = agcs[1], var = Sigma[1, 1], var_ind = Sigma_ind[1, 1]))
  }
  
  return(list(agc_vector = agcs, Sigma = Sigma, Sigma_ind = Sigma_ind))
}