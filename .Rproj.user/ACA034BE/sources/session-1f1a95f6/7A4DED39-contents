library(ggrepel)

# Helper function to add end labels to variance plots
plot_variance_with_labels <- function(data, title, subtitle = NULL) {
  
  # Get the last point for each line (for labeling)
  end_labels <- data %>%
    group_by(scenario, variance_type) %>%
    filter(n == max(n)) %>%
    ungroup()
  
  p <- ggplot(data, aes(x = n, y = variance, color = variance_type, linetype = variance_type)) +
    geom_line(linewidth = 0.8) +
    geom_point(size = 2) +
    geom_text_repel(
      data = end_labels,
      aes(label = variance_type),
      nudge_x = 0.15,
      direction = "y",
      hjust = 0,
      segment.size = 0.3,
      segment.color = "grey50",
      size = 3,
      show.legend = FALSE
    ) +
    facet_wrap(~ scenario, scales = "free_y", ncol = 2) +
    scale_x_log10(
      expand = expansion(mult = c(0.05, 0.3))  # Extra space on right for labels
    ) +
    scale_y_log10() +
    scale_color_manual(values = c(
      "Full (IID)" = "#E41A1C",
      "Independence (IID)" = "#377EB8",
      "Full (HAC)" = "#FF7F00",
      "Independence (HAC)" = "#984EA3",
      "Reference" = "#4DAF4A",
      "Empirical" = "#000000"
    )) +
    scale_linetype_manual(values = c(
      "Full (IID)" = "solid",
      "Independence (IID)" = "dashed",
      "Full (HAC)" = "solid",
      "Independence (HAC)" = "dashed",
      "Reference" = "dotted",
      "Empirical" = "dotdash"
    )) +
    labs(
      title = title,
      subtitle = subtitle,
      x = "Sample Size (n)",
      y = "Variance of Estimate"
    ) +
    theme_bw() +
    theme(
      legend.position = "none",  # Labels replace legend
      strip.text = element_text(size = 10, face = "bold"),
      plot.title = element_text(size = 14, face = "bold"),
      plot.subtitle = element_text(size = 10)
    )
  
  return(p)
}


