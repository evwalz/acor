# Compare old vs new agc_functions.R outputs
# Run from package root. Rename original to agc_functions_OLD.R first.

old_env <- new.env()
source("R/agc_functions_OLD.R", local = old_env)

new_env <- new.env()
# New version needs fenwick functions and is_binary from akc
source("R/akc_functions.R", local = new_env)
source("R/agc_functions.R", local = new_env)

set.seed(42)
N <- 100

# Continuous data
x <- rank(rnorm(N), ties.method = "average")
y <- rank(rnorm(N), ties.method = "average")
X <- rbind(rank(rnorm(N), ties.method = "average"),
           rank(rnorm(N), ties.method = "average"))

# Binary Y
y_bin <- rank(sample(c(0, 1), N, replace = TRUE), ties.method = "average")

# Ties in Y (discrete, non-binary)
y_ties <- rank(sample(1:5, N, replace = TRUE), ties.method = "average")

# Ties in X
x_ties <- rank(sample(1:10, N, replace = TRUE), ties.method = "average")
X_ties <- rbind(rank(sample(1:10, N, replace = TRUE), ties.method = "average"),
                rank(sample(1:8, N, replace = TRUE), ties.method = "average"))

# Small n
set.seed(123)
N_small <- 10
x_small <- rank(rnorm(N_small), ties.method = "average")
y_small <- rank(rnorm(N_small), ties.method = "average")
X_small <- rbind(rank(rnorm(N_small), ties.method = "average"),
                 rank(rnorm(N_small), ties.method = "average"))

compare <- function(label, old, new) {
  cat("===", label, "===\n")
  for (nm in names(old)) {
    eq <- all.equal(old[[nm]], new[[nm]])
    cat(sprintf("  %-12s %s\n", paste0(nm, ":"), if (isTRUE(eq)) "TRUE" else eq))
  }
  cat("\n")
}

# --- Original kernel ---
compare("Univariate IID (continuous)",
        old_env$Sigma_agc(y, x),
        new_env$Sigma_agc(y, x))

compare("Univariate HAC (continuous)",
        old_env$Sigma_agc_ts(y, x),
        new_env$Sigma_agc_ts(y, x))

compare("Multivariate IID (continuous)",
        old_env$Sigma_agc_multivariate(y, X),
        new_env$Sigma_agc_multivariate(y, X))

compare("Multivariate HAC (continuous)",
        old_env$Sigma_agc_multivariate_ts(y, X),
        new_env$Sigma_agc_multivariate_ts(y, X))

# --- Original kernel with ties ---
compare("Univariate IID (ties in Y)",
        old_env$Sigma_agc(y_ties, x),
        new_env$Sigma_agc(y_ties, x))

compare("Univariate HAC (ties in both)",
        old_env$Sigma_agc_ts(y_ties, x_ties),
        new_env$Sigma_agc_ts(y_ties, x_ties))

compare("Multivariate IID (ties in both)",
        old_env$Sigma_agc_multivariate(y_ties, X_ties),
        new_env$Sigma_agc_multivariate(y_ties, X_ties))

compare("Multivariate HAC (ties in both)",
        old_env$Sigma_agc_multivariate_ts(y_ties, X_ties),
        new_env$Sigma_agc_multivariate_ts(y_ties, X_ties))

# --- V2 kernel ---
compare("V2 Univariate IID",
        old_env$Sigma_agc_v2(y, x),
        new_env$Sigma_agc_v2(y, x))

compare("V2 Univariate HAC",
        old_env$Sigma_agc_ts_v2(y, x),
        new_env$Sigma_agc_ts_v2(y, x))

compare("V2 Multivariate IID",
        old_env$Sigma_agc_multivariate_v2(y, X),
        new_env$Sigma_agc_multivariate_v2(y, X))

compare("V2 Multivariate HAC",
        old_env$Sigma_agc_multivariate_ts_v2(y, X),
        new_env$Sigma_agc_multivariate_ts_v2(y, X))

# --- Binary kernel ---
compare("Binary Univariate IID",
        old_env$Sigma_agc_binary(y_bin, x),
        new_env$Sigma_agc_binary(y_bin, x))

compare("Binary Univariate HAC",
        old_env$Sigma_agc_ts_binary(y_bin, x),
        new_env$Sigma_agc_ts_binary(y_bin, x))

compare("Binary Multivariate IID",
        old_env$Sigma_agc_multivariate_binary(y_bin, X),
        new_env$Sigma_agc_multivariate_binary(y_bin, X))

compare("Binary Multivariate HAC",
        old_env$Sigma_agc_multivariate_ts_binary(y_bin, X),
        new_env$Sigma_agc_multivariate_ts_binary(y_bin, X))

# --- Small n ---
compare("Small n Univariate IID",
        old_env$Sigma_agc(y_small, x_small),
        new_env$Sigma_agc(y_small, x_small))

compare("Small n Multivariate HAC",
        old_env$Sigma_agc_multivariate_ts(y_small, X_small),
        new_env$Sigma_agc_multivariate_ts(y_small, X_small))

cat("Done! All fields should show TRUE.\n")