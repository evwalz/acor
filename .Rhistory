t_sigma_akc  <- time_med(function() Sigma_akc(X_b, Y_b))
t_conc_inf   <- time_med(function() concordance(Y_b ~ X_b, influence = TRUE))
cat(sprintf("n=%5d | Sigma_akc(): %.4fs | concordance(influence=T): %.4fs\n",
n_bench, t_sigma_akc, t_conc_inf))
}
# ============================================================================
# Verify: can concordance()$influence recover H_bar, K_tau, and Sigma_akc?
# ============================================================================
#
# We check three things in sequence:
#
#  1. Column meaning: what does each influence column count per observation?
#     (directed vs undirected, which direction, normalization)
#
#  2. H_bar recovery: does reconstructing H_bar from influence counts match
#     the direct H_bar_vec_v1() computation?
#
#  3. K_tau recovery: does K_tau from influence match K_tau_vec_v1()?
#
#  4. Sigma_akc recovery: does the variance from influence match Sigma_akc()?
#
# ============================================================================
library(survival)
library(projectR)   # replace with your package name
# ============================================================================
# Part 1: Understand the influence column counts
# ============================================================================
# Use a tiny example so we can verify by hand.
# n=5, no ties, so we only have concordant and discordant columns.
cat("============================================================\n")
cat("Part 1: Column meaning on a tiny no-ties example (n=5)\n")
cat("============================================================\n\n")
set.seed(42)
n_tiny <- 5
X_tiny <- c(1, 3, 2, 5, 4)   # known values for manual checking
Y_tiny <- c(2, 4, 1, 5, 3)
conc_tiny <- concordance(Y_tiny ~ X_tiny, influence = 2)
cat("Data:\n")
print(data.frame(i = 1:n_tiny, X = X_tiny, Y = Y_tiny))
cat("\nGlobal concordance counts:\n")
print(conc_tiny$count)
cat("\nInfluence matrix (raw):\n")
print(conc_tiny$influence)
# Manual check: for observation i=1 (X=1, Y=2),
# count how many j != 1 have X_j < X_1 (none, since X_1=1 is min)
# and how many j have X_j > X_1 with Y_j > Y_1 (concordant from i's perspective)
cat("\nManual concordant count for obs 1 (X=1, Y=2):\n")
cat("  j with (X_j > X_tiny[1]) & (Y_j > Y_tiny[1]):",
sum((X_tiny[-1] > X_tiny[1]) & (Y_tiny[-1] > Y_tiny[1])), "\n")
cat("  j with (X_j < X_tiny[1]) & (Y_j < Y_tiny[1]):",
sum((X_tiny[-1] < X_tiny[1]) & (Y_tiny[-1] < Y_tiny[1])), "\n")
cat("  sum (both directions):",
sum((X_tiny[-1] > X_tiny[1]) & (Y_tiny[-1] > Y_tiny[1])) +
sum((X_tiny[-1] < X_tiny[1]) & (Y_tiny[-1] < Y_tiny[1])), "\n")
cat("  influence[1, 'concordant'] =", conc_tiny$influence[1, "concordant"], "\n")
cat("\nManual concordant count for obs 4 (X=5, Y=5):\n")
cat("  j with (X_j > X_tiny[4]) & (Y_j > Y_tiny[4]):",
sum((X_tiny[-4] > X_tiny[4]) & (Y_tiny[-4] > Y_tiny[4])), "\n")
cat("  j with (X_j < X_tiny[4]) & (Y_j < Y_tiny[4]):",
sum((X_tiny[-4] < X_tiny[4]) & (Y_tiny[-4] < Y_tiny[4])), "\n")
cat("  sum (both directions):",
sum((X_tiny[-4] > X_tiny[4]) & (Y_tiny[-4] > Y_tiny[4])) +
sum((X_tiny[-4] < X_tiny[4]) & (Y_tiny[-4] < Y_tiny[4])), "\n")
cat("  influence[4, 'concordant'] =", conc_tiny$influence[4, "concordant"], "\n")
# ============================================================================
# Part 2: H_bar recovery
# ============================================================================
# Test two candidate formulas for H_bar from influence counts and see which
# matches H_bar_vec_v1() exactly.
#
# Candidate A (directed, i as "upper"):
#   H_bar_A[i] = (concordant_i + 0.5*tied.x_i + 0.5*tied.y_i + 0.25*tied.xy_i) / n
#
# Candidate B (both directions summed, so divide by 2 first):
#   H_bar_B[i] = (concordant_i/2 + 0.5*(tied.x_i/2) + ...) / n
#
# We test on a larger sample with ties in both X and Y.
cat("\n\n============================================================\n")
cat("Part 2: H_bar recovery from influence counts\n")
cat("============================================================\n\n")
set.seed(101)
n <- 100
X <- sample(1:10, n, replace = TRUE)   # ties in X
Y <- sample(1:5,  n, replace = TRUE)   # ties in Y
conc <- concordance(Y ~ X, influence =2)
inf  <- conc$influence
cat("Influence column names:", colnames(inf), "\n\n")
# Reference H_bar from your package
H_bar_ref <- H_bar_vec_v1(X, Y)
# Candidate A: influence counts are directed (i as observer of all others)
H_bar_A <- (inf[, "concordant"] +
0.5 * inf[, "tied.x"] +
0.5 * inf[, "tied.y"] +
0.25 * inf[, "tied.xy"]) / n
# Candidate B: counts are symmetric (each pair counted once per member)
# so effective count per obs = count / (n-1) * n  — try dividing by (n-1)
H_bar_B <- (inf[, "concordant"] +
0.5 * inf[, "tied.x"] +
0.5 * inf[, "tied.y"] +
0.25 * inf[, "tied.xy"]) / (n - 1)
cat("Max abs diff  H_bar_A vs reference:", max(abs(H_bar_A - H_bar_ref)), "\n")
cat("Max abs diff  H_bar_B vs reference:", max(abs(H_bar_B - H_bar_ref)), "\n")
cat("(Whichever is ~0 is the correct formula)\n")
# ============================================================================
# Part 3: K_tau recovery
# ============================================================================
cat("\n\n============================================================\n")
cat("Part 3: K_tau recovery\n")
cat("============================================================\n\n")
# Use whichever H_bar candidate matched
H_bar_from_inf <- if (max(abs(H_bar_A - H_bar_ref)) < max(abs(H_bar_B - H_bar_ref)))
H_bar_A else H_bar_B
F_bar_vals <- (rank(X, ties.method = "average") - 0.5) / n
G_bar_vals <- (rank(Y, ties.method = "average") - 0.5) / n
# tau_XY from concordance estimate (on [-1,1] scale for AKC)
# concordance() gives CID = (AKC + 1)/2, so tau_XY = AKC * (1 - p_Y)
if (is_binary(Y)) {
tau_Y_result <- tau_Y_func_binary(Y)
akc_result   <- kendall_tau_sign_binary(X, Y)
} else {
tau_Y_result <- tau_Y_func(Y)
akc_result   <- kendall_tau_sign(X, Y)
}
tau_XY <- akc_result$expectation
K_tau_ref  <- K_tau_vec_v1(X, Y, tau_XY)
K_tau_inf  <- 4 * H_bar_from_inf - 2 * (F_bar_vals + G_bar_vals) + 1 - tau_XY
cat("Max abs diff  K_tau from influence vs K_tau_vec_v1:",
max(abs(K_tau_inf - K_tau_ref)), "\n")
# ============================================================================
# Part 4: Full Sigma_akc recovery
# ============================================================================
cat("\n\n============================================================\n")
cat("Part 4: Full Sigma_akc recovery from concordance() call\n")
cat("============================================================\n\n")
tau_Y  <- tau_Y_result$expectation
p_Y    <- tau_Y_result$p_tie_y
akc    <- akc_result$tau
# K_p values (O(n), unchanged)
K_p_vals <- K_p_vec_v1(Y, tau_Y)
# Adjusted kernel using influence-based K_tau
adjusted_K_inf <- K_tau_inf - (tau_XY / (1 - p_Y)) * K_p_vals
# Variance from influence path
scale_factor <- 4 / (1 - p_Y)^2
var_inf      <- scale_factor * mean(adjusted_K_inf^2)
# Reference variance from Sigma_akc()
ref <- Sigma_akc(X, Y)
cat("AKC estimate  — reference:", ref$akc,  " | from concordance:", akc, "\n")
cat("Variance      — reference:", ref$var,  " | from influence:  ", var_inf, "\n")
cat("Max abs diff in variance: ", abs(ref$var - var_inf), "\n")
cat("\n\n============================================================\n")
cat("Part 5: Timing comparison on larger n\n")
cat("============================================================\n\n")
time_med <- function(expr_fn, reps = 10) {
median(replicate(reps, system.time(expr_fn())["elapsed"]))
}
for (n_bench in c(500, 2000, 5000)) {
set.seed(200 + n_bench)
X_b <- rnorm(n_bench)
Y_b <- rnorm(n_bench)
t_sigma_akc  <- time_med(function() Sigma_akc(X_b, Y_b))
t_conc_inf   <- time_med(function() concordance(Y_b ~ X_b, influence = 2))
cat(sprintf("n=%5d | Sigma_akc(): %.4fs | concordance(influence=T): %.4fs\n",
n_bench, t_sigma_akc, t_conc_inf))
}
cat("\nDone.\n")
# ============================================================================
# Check: recover K_tau and Sigma_akc from concordance(influence=2)
# ============================================================================
#
# From the output we know:
#   influence[i, "concordant"] = #{j: X_j > X_i & Y_j > Y_i}   (i is lower)
#                              + #{j: X_j < X_i & Y_j < Y_i}   (i is upper)
#   i.e. both directions, each pair counted once per member
#
# H_bar(x_i, y_i) only needs the "upper" term: #{j: X_j < X_i & Y_j < Y_i} / n
# So the naive formula was wrong. We need to work with the NET count instead:
#   net_i = concordant_i - discordant_i
#         = [#{j: X_j<X_i & Y_j<Y_i} - #{j: X_j>X_i & Y_j<Y_i} - ...]
#         = upper_i - lower_i  (roughly)
#
# This net count is the IJ influence function of concordance, which should
# relate directly to K_tau. We check what normalization gives K_tau exactly.
# ============================================================================
library(survival)
library(projectR)
# ============================================================================
# Part 1: Verify directionality understanding on tiny example
# ============================================================================
cat("============================================================\n")
cat("Part 1: Directed decomposition on tiny example (n=5)\n")
cat("============================================================\n\n")
X_tiny <- c(1, 3, 2, 5, 4)
Y_tiny <- c(2, 4, 1, 5, 3)
n_tiny <- 5
conc_tiny <- concordance(Y_tiny ~ X_tiny, influence = 2)
inf_tiny  <- conc_tiny$influence
cat("Influence matrix:\n")
print(inf_tiny)
cat(sprintf("\nTotal concordant pairs: %g\n", conc_tiny$count["concordant"]))
cat(sprintf("Sum of influence[,'concordant']: %g  (= 2 x total: each pair counted in both members)\n\n",
sum(inf_tiny[, "concordant"])))
cat(sprintf("  %3s  %8s  %8s  %8s  %8s\n", "i", "upper", "lower", "inf[c]", "net(u-l)"))
for (i in 1:n_tiny) {
upper <- sum((X_tiny[-i] < X_tiny[i]) & (Y_tiny[-i] < Y_tiny[i]))
lower <- sum((X_tiny[-i] > X_tiny[i]) & (Y_tiny[-i] > Y_tiny[i]))
cat(sprintf("  %3d  %8d  %8d  %8g  %8d\n",
i, upper, lower, inf_tiny[i, "concordant"], upper - lower))
}
cat("\nnet_i = upper_i - lower_i = concordant_i - discordant_i (verify):\n")
cat(sprintf("  inf[,'concordant'] - inf[,'discordant'] = %s\n",
paste(inf_tiny[,"concordant"] - inf_tiny[,"discordant"], collapse=" ")))
# ============================================================================
# Part 2: Does net_i / (n-1) = K_tau_i ?
# ============================================================================
cat("\n\n============================================================\n")
cat("Part 2: Does (concordant_i - discordant_i) / (n-1) == K_tau_i?\n")
cat("============================================================\n\n")
check_net_vs_K_tau <- function(X, Y, label) {
n     <- length(X)
conc  <- concordance(Y ~ X, influence = 2)
inf   <- conc$influence
net   <- inf[, "concordant"] - inf[, "discordant"]
if (is_binary(Y)) {
tau_Y_res <- tau_Y_func_binary(Y)
akc_res   <- kendall_tau_sign_binary(X, Y)
} else {
tau_Y_res <- tau_Y_func(Y)
akc_res   <- kendall_tau_sign(X, Y)
}
tau_XY    <- akc_res$expectation
K_tau_ref <- K_tau_vec_v1(X, Y, tau_XY)
# Test candidates
candidates <- list(
"net / n"         = net / n,
"net / (n-1)"     = net / (n - 1),
"net * 2 / n"     = net * 2 / n,
"net * 2 / (n-1)" = net * 2 / (n - 1)
)
cat(sprintf("  %s  (n=%d)\n", label, n))
for (nm in names(candidates)) {
err <- max(abs(candidates[[nm]] - K_tau_ref))
cat(sprintf("    Max|%s - K_tau_ref|: %.2e%s\n",
nm, err, if (err < 1e-8) "  <-- MATCH" else ""))
}
cat("\n")
}
set.seed(101)
check_net_vs_K_tau(rnorm(200), rnorm(200),                         "continuous X & Y")
check_net_vs_K_tau(sample(1:10,200,TRUE), rnorm(200),              "discrete X (10 lv)")
check_net_vs_K_tau(sample(1:10,200,TRUE), sample(1:5,200,TRUE),    "discrete X+Y (10x5)")
check_net_vs_K_tau(rnorm(200), rbinom(200, 1, 0.5),                "binary Y")
# ============================================================================
# Part 3: Does the IJ variance from concordance() equal Sigma_akc / n?
# ============================================================================
cat("============================================================\n")
cat("Part 3: concordance()$var vs Sigma_akc()$var / n\n")
cat("============================================================\n\n")
check_var <- function(X, Y, label) {
n    <- length(X)
conc <- concordance(Y ~ X, influence = 2)
ref  <- Sigma_akc(X, Y)
# concordance()$var is the IJ variance of the CID (concordance) statistic
# Sigma_akc()$var is the asymptotic variance of AKC = 2*CID - 1
# So Var(AKC) = 4 * Var(CID), meaning Sigma_akc$var = 4 * n * concordance$var
conc_var_scaled <- 4 * n * conc$var
cat(sprintf("  %s\n", label))
cat(sprintf("    Sigma_akc()$var:          %.8f\n", ref$var))
cat(sprintf("    4 * n * concordance$var:  %.8f\n", conc_var_scaled))
cat(sprintf("    abs diff:                 %.2e\n\n", abs(ref$var - conc_var_scaled)))
}
set.seed(201)
check_var(rnorm(300), rnorm(300),                         "continuous X & Y")
check_var(sample(1:10,300,TRUE), rnorm(300),              "discrete X (10 lv)")
check_var(sample(1:10,300,TRUE), sample(1:5,300,TRUE),    "discrete X+Y (10x5)")
check_var(rnorm(300), rbinom(300, 1, 0.5),                "binary Y")
# ============================================================================
# Part 4: Reconstruct Sigma_akc directly from concordance influence
# ============================================================================
# If net_i / (n-1) = K_tau_i, then:
#   adjusted_K_i = K_tau_i - (tau/(1-p_Y)) * K_p_i
#                = net_i/(n-1) - (tau/(1-p_Y)) * K_p_i
# and Sigma_akc$var = 4/(1-p_Y)^2 * mean(adjusted_K^2)
cat("============================================================\n")
cat("Part 4: Reconstruct Sigma_akc from concordance influence\n")
cat("============================================================\n\n")
reconstruct_sigma <- function(X, Y, label, K_tau_formula) {
n    <- length(X)
conc <- concordance(Y ~ X, influence = 2)
inf  <- conc$influence
net  <- inf[, "concordant"] - inf[, "discordant"]
if (is_binary(Y)) {
tau_Y_res <- tau_Y_func_binary(Y)
akc_res   <- kendall_tau_sign_binary(X, Y)
} else {
tau_Y_res <- tau_Y_func(Y)
akc_res   <- kendall_tau_sign(X, Y)
}
tau_XY <- akc_res$expectation
tau_Y  <- tau_Y_res$expectation
p_Y    <- tau_Y_res$p_tie_y
K_tau_inf  <- K_tau_formula(net, n)
K_p_vals   <- K_p_vec_v1(Y, tau_Y)
adjusted_K <- K_tau_inf - (tau_XY / (1 - p_Y)) * K_p_vals
var_inf    <- (4 / (1 - p_Y)^2) * mean(adjusted_K^2)
ref <- Sigma_akc(X, Y)
cat(sprintf("  %s\n", label))
cat(sprintf("    var reference:  %.8f\n", ref$var))
cat(sprintf("    var from inf:   %.8f\n", var_inf))
cat(sprintf("    abs diff:       %.2e\n\n", abs(ref$var - var_inf)))
}
# Use the formula that matched in Part 2
best_formula <- function(net, n) net / (n - 1)
set.seed(301)
reconstruct_sigma(rnorm(300), rnorm(300),
"continuous X & Y", best_formula)
reconstruct_sigma(sample(1:10,300,TRUE), rnorm(300),
"discrete X (10 lv)", best_formula)
reconstruct_sigma(sample(1:10,300,TRUE), sample(1:5,300,TRUE),
"discrete X+Y (10x5)", best_formula)
reconstruct_sigma(rnorm(300), rbinom(300, 1, 0.5),
"binary Y", best_formula)
# ============================================================================
# Find exact normalization: net_i -> K_tau_i
# ============================================================================
# The differences with net/(n-1) are small but consistent and grow with ties,
# suggesting a normalization issue rather than a formula error.
# We try all plausible normalizations systematically.
# ============================================================================
library(survival)
library(projectR)
check_normalizations <- function(X, Y, label) {
n     <- length(X)
conc  <- concordance(Y ~ X, influence = 2)
inf   <- conc$influence
net   <- inf[, "concordant"] - inf[, "discordant"]
if (is_binary(Y)) {
tau_Y_res <- tau_Y_func_binary(Y)
akc_res   <- kendall_tau_sign_binary(X, Y)
} else {
tau_Y_res <- tau_Y_func(Y)
akc_res   <- kendall_tau_sign(X, Y)
}
tau_XY    <- akc_res$expectation
K_tau_ref <- K_tau_vec_v1(X, Y, tau_XY)
n_pairs      <- n * (n - 1) / 2
n_comparable <- conc$count["concordant"] + conc$count["discordant"]
candidates <- list(
"net / n"                    = net / n,
"net / (n-1)"                = net / (n - 1),
"net * 2 / n"                = net * 2 / n,
"net * 2 / (n-1)"            = net * 2 / (n - 1),
"net / n_comparable * n"     = net / n_comparable * n,
"net / n_comparable * (n-1)" = net / n_comparable * (n - 1)
)
cat(sprintf("\n%s  (n=%d, n_comparable=%g / %g pairs)\n",
label, n, n_comparable, n_pairs))
for (nm in names(candidates)) {
err  <- max(abs(candidates[[nm]] - K_tau_ref))
flag <- if (err < 1e-8) "  <-- EXACT" else if (err < 1e-3) "  <-- close" else ""
cat(sprintf("  Max|%-36s - K_tau|: %.2e%s\n", nm, err, flag))
}
# Best-fit scalar
k_ls   <- sum(net * K_tau_ref) / sum(net^2)
err_ls <- max(abs(k_ls * net - K_tau_ref))
cat(sprintf("  Best LS scalar: k=%.8f  (1/(n-1)=%.8f)  Max err: %.2e\n",
k_ls, 1/(n-1), err_ls))
}
set.seed(101)
check_normalizations(rnorm(200), rnorm(200),
"continuous X & Y")
check_normalizations(sample(1:10, 200, TRUE), rnorm(200),
"discrete X (10 lv), continuous Y")
check_normalizations(sample(1:10, 200, TRUE), sample(1:5, 200, TRUE),
"discrete X+Y (10x5)")
check_normalizations(rnorm(200), rbinom(200, 1, 0.5),
"binary Y")
check_normalizations(sample(1:2, 200, TRUE), rbinom(200, 1, 0.5),
"binary X & Y (extreme ties)")
# ============================================================================
# Check: does adding back tied pair contributions fix the gap?
# concordance() puts tied pairs into tied.x / tied.y / tied.xy columns.
# K_tau includes these with 0.5 weights via H_bar. So the net count is missing
# the directed contribution of tied pairs. We reconstruct those manually.
# ============================================================================
cat("\n\n============================================================\n")
cat("Check: does adding back tied pair contributions fix the gap?\n")
cat("============================================================\n\n")
check_with_ties <- function(X, Y, label) {
n    <- length(X)
conc <- concordance(Y ~ X, influence = 2)
inf  <- conc$influence
if (is_binary(Y)) {
tau_Y_res <- tau_Y_func_binary(Y)
akc_res   <- kendall_tau_sign_binary(X, Y)
} else {
tau_Y_res <- tau_Y_func(Y)
akc_res   <- kendall_tau_sign(X, Y)
}
tau_XY    <- akc_res$expectation
K_tau_ref <- K_tau_vec_v1(X, Y, tau_XY)
# Net from concordant/discordant only (ignores tied pairs)
net <- inf[, "concordant"] - inf[, "discordant"]
# Tied-X pairs: same X_i = X_j, different Y.
# H_bar gives weight 0.5 to these. Their directed contribution to K_tau for obs i:
#   +0.5 for each j with X_j = X_i & Y_j < Y_i  (j is below i)
#   -0.5 for each j with X_j = X_i & Y_j > Y_i  (j is above i)
# Similarly for tied-Y pairs.
net_tied_x <- numeric(n)
net_tied_y <- numeric(n)
for (i in seq_len(n)) {
same_x <- X[-i] == X[i]
if (any(same_x)) {
net_tied_x[i] <- 0.5 * sum(Y[-i][same_x] < Y[i]) -
0.5 * sum(Y[-i][same_x] > Y[i])
}
same_y <- Y[-i] == Y[i]
if (any(same_y)) {
net_tied_y[i] <- 0.5 * sum(X[-i][same_y] < X[i]) -
0.5 * sum(X[-i][same_y] > X[i])
}
}
net_extended <- (net + net_tied_x + net_tied_y) / (n - 1)
cat(sprintf("  %s\n", label))
cat(sprintf("    Max|net/(n-1) - K_tau|:                  %.2e\n",
max(abs(net / (n - 1) - K_tau_ref))))
cat(sprintf("    Max|(net + tied_x + tied_y)/(n-1) - K_tau|: %.2e\n",
max(abs(net_extended - K_tau_ref))))
cat("\n")
}
set.seed(201)
check_with_ties(rnorm(200), rnorm(200),
"continuous X & Y")
check_with_ties(sample(1:10, 200, TRUE), rnorm(200),
"discrete X (10 lv)")
check_with_ties(sample(1:10, 200, TRUE), sample(1:5, 200, TRUE),
"discrete X+Y (10x5)")
check_with_ties(rnorm(200), rbinom(200, 1, 0.5),
"binary Y")
check_with_ties(sample(1:2, 200, TRUE), rbinom(200, 1, 0.5),
"binary X & Y (extreme ties)")
devtools::load_all()
devtools::load_all()
testthat::test_file('tests/testthat/test_agc_versions.R')
run_agc_benchmark()
source('tests/testthat/test_agc_versions.R')
run_agc_benchmark()
source('tests/testthat/test_agc_versions.R')
run_agc_benchmark()
run_agc_benchmarks()
devtools::load_all()
testthat::test_file('tests/testthat/test_agc_versions.R')
testthat::test_file('tests/testthat/test_acor_test0.R')
source('tests/testthat/test_agc_versions.R')
run_agc_benchmarks()
# Quick benchmark: AGC kernel versions for binary Y
# Run interactively to check if binary specialization is faster
library(projectR)  # Replace with your actual package name
# source("agc_functions_binary.R")  # if not yet in package
make_ranks <- function(X, Y) {
y_rank <- rank(Y, ties.method = "average")
x_rank <- rank(X, ties.method = "average")
list(y_rank = y_rank, x_rank = x_rank)
}
time_med <- function(expr_fn, reps = 5) {
median(replicate(reps, system.time(expr_fn())["elapsed"]))
}
cat("\n")
cat(strrep("=", 70), "\n")
cat("  AGC binary Y benchmark: original vs binary vs v2 (IID)\n")
cat(strrep("=", 70), "\n")
cat(sprintf("  %-20s  %10s  %10s  %10s\n", "Scenario", "original", "binary", "v2"))
cat(strrep("-", 70), "\n")
for (n in c(200, 500, 2000, 5000, 10000)) {
set.seed(42)
X <- rnorm(n)
Y <- rbinom(n, 1, 0.5)
rk <- make_ranks(X, Y)
t_orig   <- time_med(function() Sigma_agc(rk$y_rank, rk$x_rank))
t_binary <- time_med(function() Sigma_agc_binary(rk$y_rank, rk$x_rank))
t_v2     <- time_med(function() Sigma_agc_v2(rk$y_rank, rk$x_rank))
fastest <- which.min(c(t_orig, t_binary, t_v2))
marks <- c("", "", "")
marks[fastest] <- "*"
cat(sprintf("  n=%-17d  %9.4f%s  %9.4f%s  %9.4f%s\n",
n, t_orig, marks[1], t_binary, marks[2], t_v2, marks[3]))
}
cat(strrep("-", 70), "\n")
cat("  * = fastest\n\n")
# Also check correctness
cat("Correctness check (n=1000, binary Y):\n")
set.seed(99); n <- 1000
X <- rnorm(n); Y <- rbinom(n, 1, 0.5)
rk <- make_ranks(X, Y)
r_orig   <- Sigma_agc(rk$y_rank, rk$x_rank)
r_binary <- Sigma_agc_binary(rk$y_rank, rk$x_rank)
cat(sprintf("  agc:     orig=%.10f  binary=%.10f  match=%s\n",
r_orig$agc, r_binary$agc, all.equal(r_orig$agc, r_binary$agc, tolerance = 1e-10)))
cat(sprintf("  var:     orig=%.10f  binary=%.10f  match=%s\n",
r_orig$var, r_binary$var, all.equal(r_orig$var, r_binary$var, tolerance = 1e-10)))
cat(sprintf("  var_ind: orig=%.10f  binary=%.10f  match=%s\n",
r_orig$var_ind, r_binary$var_ind, all.equal(r_orig$var_ind, r_binary$var_ind, tolerance = 1e-10)))
source('tests/testthat/test_akc_versions.R')
run_acor_benchmarks()
devtools::load_all()
source('tests/testthat/test_akc_versions.R')
run_acor_benchmarks()
set.seed(42); n <- 2000
X <- sample(1:10, n, replace = TRUE); Y <- rnorm(n)
y_rank <- rank(Y, ties.method = "average")
x_rank <- rank(X, ties.method = "average")
cat("original:", system.time(for(i in 1:5) Sigma_agc(y_rank, x_rank))["elapsed"] / 5, "s\n")
cat("v2:      ", system.time(for(i in 1:5) Sigma_agc_v2(y_rank, x_rank))["elapsed"] / 5, "s\n")
